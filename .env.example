# ============================================================
#  .env.example — نموذج متغيرات البيئة
#  انسخ هذا الملف: cp .env.example .env ثم أضف القيم الحقيقية
#  لا ترفع .env على GitHub!
# ============================================================

# ── Rasa Pro License ────────────────────────────────────────
RASA_PRO_LICENSE=your-rasa-pro-license-key

# ── OpenAI ──────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Database ────────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=alazab_chatbot
DB_USER=alazab_user
DB_PASSWORD=change_me_strong_password

# ── Redis ───────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis_password
REDIS_USE_SSL=false

# ── Public URLs ─────────────────────────────────────────────
PUBLIC_BASE_URL=https://chat.alazab.com
ALLOWED_ORIGINS=https://alazab.com,https://www.alazab.com,https://chat.alazab.com
RASA_URL=http://rasa:5005
ACTION_SERVER_URL=http://rasa-actions:5055/webhook

# ── WhatsApp Business API (Meta Cloud) ──────────────────────
WHATSAPP_API_URL=https://graph.facebook.com/v18.0/PHONE_NUMBER_ID/messages
WHATSAPP_TOKEN=your_whatsapp_bearer_token
NOTIFY_PHONE=201XXXXXXXXX          # رقم الواتساب لاستقبال إشعارات الفريق

# ── Meta (Facebook Messenger) ───────────────────────────────
FB_VERIFY_TOKEN=alazab_verify_2025
FB_APP_SECRET=your_app_secret
FB_PAGE_ACCESS_TOKEN=your_page_token

# ── Telegram ────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token   # من @BotFather
NOTIFY_TG_CHAT_ID=your_team_chat_id          # Chat ID للفريق (-100xxxxxxxxx)

# ── CRM / External Webhook ──────────────────────────────────
WEBHOOK_NOTIFY_URL=https://crm.alazab.com/webhook

# ── UberFix API ─────────────────────────────────────────────
UBERFIX_API_URL=https://api.uberfix.com/v1
UBERFIX_API_KEY=your_uberfix_api_key

# ── Deployment ──────────────────────────────────────────────
TRAIN_ON_DEPLOY=false
COMPOSE_PROJECT_NAME=alazab_rasa

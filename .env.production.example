# Production environment template for Alazab Rasa stack.
# Copy to .env.production on the production server and fill real rotated values.

# Required licenses and AI keys
RASA_PRO_LICENSE=replace-with-production-rasa-pro-license
OPENAI_API_KEY=replace-with-production-openai-project-key
OPENAI_ORG_ID=replace-with-production-openai-org-id
OPENAI_PROJECT_ID=
AUDIO_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe

# Admin protection
ADMIN_API_KEY=replace-with-long-random-admin-token

# Core services
DB_HOST=postgres
DB_PORT=5432
DB_NAME=alazab_chatbot
DB_USER=alazab_user
DB_PASSWORD=replace-with-production-db-password
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=replace-with-production-redis-password
REDIS_USE_SSL=false
REDIS_DB=0

# Public endpoints
PUBLIC_BASE_URL=https://chat.alazab.com
ALLOWED_ORIGINS=https://alazab.com,https://www.alazab.com,https://brand-identity.alazab.com,https://laban-alasfour.alazab.com,https://luxury-finishing.alazab.com,https://uberfix.alazab.com,https://chat.alazab.com
RASA_URL=http://rasa:5005
ACTION_SERVER_URL=http://rasa-actions:5055/webhook
MAX_UPLOAD_BYTES=12582912

# Optional channels
FB_VERIFY_TOKEN=replace-if-meta-enabled
FB_APP_SECRET=replace-if-meta-enabled
FB_PAGE_ACCESS_TOKEN=replace-if-messenger-enabled
FB_APP_ID=
WHATSAPP_API_URL=replace-if-whatsapp-enabled
WHATSAPP_TOKEN=replace-if-whatsapp-enabled
TELEGRAM_BOT_TOKEN=replace-if-telegram-enabled
NOTIFY_TG_CHAT_ID=replace-if-telegram-notifications-enabled

# Notifications and integrations
NOTIFY_PHONE=
WEBHOOK_NOTIFY_URL=
UBERFIX_API_URL=
UBERFIX_API_KEY=
DEEPGRAM_API_KEY=
CARTESIA_API_KEY=

# Deployment behavior
TRAIN_ON_DEPLOY=false
COMPOSE_PROJECT_NAME=alazab_rasa_prod
NODE_ENV=production

# Images
RASA_IMAGE=rasa/rasa-pro:3.16.3
STUDIO_IMAGE_TAG=1.15.2
STUDIO_IMAGE_PATH=rasa
RASA_PRO_IMAGE=rasa/rasa-pro:3.16.3

# Server metadata
PUBLIC_IP=158.101.231.62
LOCAL_IP=10.0.1.153
HOSTNAME=azab-server

# App secrets
JWT_SECRET=replace-with-32-byte-base64-secret
ENCRYPTION_KEY=replace-with-32-byte-base64-secret

# ============================================================
# Alazab Rasa - Python-only runtime environment
# Copy to .env.nodocker and fill real production/staging values.
# Do not use Docker service names here.
# ============================================================

# Required
RASA_PRO_LICENSE=replace-with-rasa-pro-license
OPENAI_API_KEY=replace-with-openai-project-key
OPENAI_ORG_ID=
OPENAI_PROJECT_ID=
ADMIN_API_KEY=replace-with-long-random-admin-token

# Runtime URLs
PUBLIC_BASE_URL=https://chat.alazab.com
ALLOWED_ORIGINS=https://alazab.com,https://www.alazab.com,https://brand-identity.alazab.com,https://laban-alasfour.alazab.com,https://luxury-finishing.alazab.com,https://uberfix.alazab.com,https://chat.alazab.com
RASA_URL=http://127.0.0.1:5005
ACTION_SERVER_URL=http://127.0.0.1:5055/webhook

# Rasa tracker/event broker database.
# Point these to the real company production/staging database if that is the source of operational data.
DB_HOST=replace-with-real-postgres-host
DB_PORT=5432
DB_NAME=replace-with-real-database-name
DB_USER=replace-with-real-database-user
DB_PASSWORD=replace-with-real-database-password

# Redis for sessions, locks, tracker cache.
# Point to real Redis or managed Redis. Do not use "redis" unless Redis is really resolvable from the server.
REDIS_HOST=replace-with-real-redis-host
REDIS_PORT=6379
REDIS_PASSWORD=replace-with-real-redis-password
REDIS_USE_SSL=false
REDIS_DB=0

# Voice
AUDIO_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
MAX_UPLOAD_BYTES=12582912

# Company systems / integrations
CRM_API_URL=
CRM_API_KEY=
PRICING_API_URL=
PRICING_API_KEY=
CATALOG_API_URL=
CATALOG_API_KEY=
UBERFIX_API_URL=
UBERFIX_API_KEY=
WEBHOOK_NOTIFY_URL=
NOTIFY_PHONE=

# Channels
FB_VERIFY_TOKEN=
FB_APP_SECRET=
FB_PAGE_ACCESS_TOKEN=
FB_APP_ID=
WHATSAPP_API_URL=
WHATSAPP_TOKEN=
TELEGRAM_BOT_TOKEN=
NOTIFY_TG_CHAT_ID=

# App secrets
JWT_SECRET=replace-with-32-byte-base64-secret
ENCRYPTION_KEY=replace-with-32-byte-base64-secret
